# 印尼智能催收系统 环境变量配置模板
# 复制为.env文件，根据实际环境修改配置
# 注意：.env文件包含敏感信息，绝对不能提交到Git仓库！

###########################################################################
# 基础配置
###########################################################################
# 运行环境：development/test/production
ENV=development
# API服务端口
API_PORT=8000

###########################################################################
# 数据库配置
###########################################################################
# SQLite 配置（开发环境用）
DB_URI=sqlite:///./data/collection.db
# MySQL 配置（生产环境用）
# DB_URI=mysql+pymysql://user:password@host:port/collection?charset=utf8mb4

###########################################################################
# 第三方服务配置（根据实际需要添加）
###########################################################################
# ASR 语音识别服务配置
# ASR_API_KEY=your-asr-api-key
# ASR_API_URL=https://your-asr-service.com/api

# TTS 语音合成服务配置
# TTS_API_KEY=your-tts-api-key
# TTS_API_URL=https://your-tts-service.com/api

# 翻译服务配置（如果使用在线翻译）
# TRANSLATE_API_KEY=your-translate-api-key

###########################################################################
# 安全配置
###########################################################################
# API密钥（如果需要API鉴权）
# API_SECRET_KEY=your-secret-key
# JWT_SECRET_KEY=your-jwt-secret-key

###########################################################################
# 业务配置
###########################################################################
# 催收业务配置
# DEFAULT_CALL_TIMEOUT=60
# MAX_PUSH_COUNT=3
# COMPLIANCE_CHECK_ENABLED=true
